rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Rules
    match /users/{userId} {
      function isValidProfile(data) {
        return data.uid == request.auth.uid 
          && data.highScore is int 
          && data.totalCoins is int
          && data.unlockedSkins is list
          && data.selectedSkin is string
          && data.displayName is string
          && data.displayName.size() <= 50;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidProfile(incoming()) && incoming().highScore == 0;
      allow update: if isOwner(userId) && isValidProfile(incoming()) && (
        // Action: Update Score/Coins
        incoming().diff(existing()).affectedKeys().hasOnly(['highScore', 'totalCoins', 'updatedAt', 'displayName']) ||
        // Action: Unlock/Switch Skin
        incoming().diff(existing()).affectedKeys().hasOnly(['unlockedSkins', 'selectedSkin', 'totalCoins', 'updatedAt'])
      );
    }

    // Leaderboard Rules
    match /leaderboard/{userId} {
      function isValidEntry(data) {
        return data.uid == request.auth.uid
          && data.score is int
          && data.displayName is string
          && data.displayName.size() <= 50;
      }

      allow list: if true; // Public leaderboard
      allow get: if true;
      allow create: if isOwner(userId) && isValidEntry(incoming());
      allow update: if isOwner(userId) && isValidEntry(incoming()) && incoming().score >= existing().score;
    }
  }
}
