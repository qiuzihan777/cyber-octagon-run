{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and game progress",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "highScore": { "type": "number" },
        "totalCoins": { "type": "number" },
        "unlockedSkins": { "type": "array", "items": { "type": "string" } },
        "selectedSkin": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "highScore", "totalCoins"]
    },
    "LeaderboardEntry": {
      "title": "Leaderboard Entry",
      "description": "Public high score entry",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "score": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "score"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Private user profiles"
    },
    "leaderboard/{userId}": {
      "schema": "LeaderboardEntry",
      "description": "Public high scores"
    }
  }
}
